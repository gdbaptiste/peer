<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Autopeer - The Trusted Marketplace for Private Car Sales</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .bg-hero {
            background-image: url('https://images.unsplash.com/photo-1493238792000-8113da705763?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7); }
            50% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); }
        }
        .btn-pulse {
            animation: pulse 2.5s infinite;
        }
    </style>
</head>
<body class="bg-white text-slate-800 antialiased">

    <!-- Header / Logo -->
    <header class="absolute top-0 left-0 w-full p-6 z-20">
        <div class="container mx-auto">
            <h1 class="text-3xl font-bold text-white tracking-wider">Auto<span class="text-blue-400">peer</span></h1>
        </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section class="bg-hero relative">
            <div class="absolute inset-0 bg-black/60"></div>
            <div class="relative z-10 pt-32 pb-20 md:pt-40 md:pb-28 text-white">
                <div class="container mx-auto px-6 text-center">
                    <h2 class="text-4xl md:text-6xl font-extrabold leading-tight mb-5">
                        The trusted marketplace for private car sales.
                    </h2>
                    <p class="text-lg md:text-xl text-slate-300 mb-10 max-w-3xl mx-auto">
                        Real deals. Clear terms. Total control.
                    </p>

                    <!-- Email Capture & Countdown -->
                    <div class="max-w-xl mx-auto bg-slate-800/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-700">
                        <p class="font-semibold mb-4 text-white">Start the engine of change.</p>
                         <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 transition-all duration-300">
                            <input type="email" id="email-input" placeholder="Enter your email" required class="w-full px-5 py-4 rounded-lg bg-slate-900/70 border-2 border-slate-600 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/50 outline-none transition-all text-white placeholder-slate-400">
                            <button type="submit" class="bg-blue-600 text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-700 transition-all duration-300 shadow-lg flex-shrink-0 btn-pulse">
                                Own the Deal
                            </button>
                        </form>
                        <div id="success-message" class="hidden mt-4 text-green-300 font-semibold">
                            <span>Thank you! We'll notify you at launch.</span>
                        </div>
                        <!-- Countdown Timer -->
                        <div id="countdown" class="grid grid-cols-4 gap-3 max-w-xs mx-auto mt-6 text-white">
                            <div class="p-2 rounded-lg">
                                <div id="days" class="text-3xl font-bold">00</div>
                                <div class="text-xs text-slate-400 uppercase">Days</div>
                            </div>
                            <div class="p-2 rounded-lg">
                                <div id="hours" class="text-3xl font-bold">00</div>
                                <div class="text-xs text-slate-400 uppercase">Hours</div>
                            </div>
                            <div class="p-2 rounded-lg">
                                <div id="minutes" class="text-3xl font-bold">00</div>
                                <div class="text-xs text-slate-400 uppercase">Minutes</div>
                            </div>
                            <div class="p-2 rounded-lg">
                                <div id="seconds" class="text-3xl font-bold">00</div>
                                <div class="text-xs text-slate-400 uppercase">Seconds</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Problem Section -->
        <section class="py-20 md:py-28 bg-white">
            <div class="container mx-auto px-6">
                 <div class="text-center max-w-3xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Buying a Used Car Privately Is Broken.</h2>
                    <p class="text-lg text-slate-600">Sellers lose money and buyers face scams. The process leaves everyone feeling vulnerable and frustrated.</p>
                </div>
                <div class="grid md:grid-cols-3 gap-8 mt-12 text-center">
                    <!-- Pain Point Card -->
                    <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200">
                        <div class="text-red-500 mb-4 inline-flex items-center justify-center text-3xl">😟</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-2">Massive Trust Deficit</h3>
                        <p class="text-slate-600">High risk of fraud, misleading ads, and unsafe meetups. <span class="font-semibold text-slate-800">1 in 3</span> private sales end in a major dispute.</p>
                    </div>
                     <!-- Pain Point Card -->
                    <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200">
                        <div class="text-yellow-500 mb-4 inline-flex items-center justify-center text-3xl">💸</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-2">Value Loss & Complexity</h3>
                        <p class="text-slate-600">Complex paperwork and pricing uncertainty mean sellers earn <span class="font-semibold text-slate-800">~20% less</span> than dealer trade-ins.</p>
                    </div>
                     <!-- Pain Point Card -->
                    <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200">
                         <div class="text-gray-500 mb-4 inline-flex items-center justify-center text-3xl">🚫</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-2">No Support or Security</h3>
                        <p class="text-slate-600">No integrated inspections or secure payment options, leaving both parties exposed to risk.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="py-20 md:py-28 bg-slate-50">
             <div class="container mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
                <div class="max-w-md">
                    <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Our Guarantees</h2>
                    <p class="text-lg text-slate-600">We provide the tools and support necessary to ensure every transaction is smooth, transparent, and secure from start to finish.</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <!-- Feature Card -->
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                        <div class="text-blue-600 text-2xl mb-3">🔐</div>
                        <h4 class="font-bold text-lg text-slate-900">Secure Escrow Payments</h4>
                        <p class="text-slate-600 text-sm">We hold funds securely until the car is delivered and the deal is confirmed.</p>
                    </div>
                    <!-- Feature Card -->
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                        <div class="text-blue-600 text-2xl mb-3">🤖</div>
                        <h4 class="font-bold text-lg text-slate-900">AI & Mechanic Inspections</h4>
                        <p class="text-slate-600 text-sm">Transparent, reliable vehicle condition reports so there are no surprises.</p>
                    </div>
                    <!-- Feature Card -->
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                        <div class="text-blue-600 text-2xl mb-3">🧾</div>
                        <h4 class="font-bold text-lg text-slate-900">Automated Paperwork</h4>
                        <p class="text-slate-600 text-sm">Our guided process makes complex paperwork like title transfers simple.</p>
                    </div>
                    <!-- Feature Card -->
                    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
                        <div class="text-blue-600 text-2xl mb-3">🧑‍💻</div>
                        <h4 class="font-bold text-lg text-slate-900">Verified Users</h4>
                        <p class="text-slate-600 text-sm">We mandate identity verification to build a community of trusted users.</p>
                    </div>
                </div>
             </div>
        </section>

         <!-- How it Works Section -->
        <section class="py-20 md:py-28 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center max-w-3xl mx-auto">
                    <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">We Handle the Deal. You Drive.</h2>
                    <p class="text-lg text-slate-600">Our 3-step process is designed for simplicity and security.</p>
                </div>
                <div class="mt-16 relative">
                    <!-- Connecting line -->
                    <div class="absolute top-8 left-0 w-full h-0.5 bg-slate-200 hidden md:block"></div>
                    <div class="grid md:grid-cols-3 gap-12 relative">
                         <!-- Step -->
                        <div class="text-center">
                            <div class="mb-4 inline-flex items-center justify-center w-16 h-16 rounded-full bg-white border-2 border-blue-500 text-blue-600 font-bold text-2xl shadow-md">1</div>
                            <h3 class="font-bold text-xl text-slate-900 mb-2">List & Verify</h3>
                            <p class="text-slate-600">Sellers list their car in minutes. We verify the vehicle, owner, and title to ensure legitimacy.</p>
                        </div>
                         <!-- Step -->
                         <div class="text-center">
                            <div class="mb-4 inline-flex items-center justify-center w-16 h-16 rounded-full bg-white border-2 border-blue-500 text-blue-600 font-bold text-2xl shadow-md">2</div>
                            <h3 class="font-bold text-xl text-slate-900 mb-2">Inspect & Pay</h3>
                            <p class="text-slate-600">Buyers schedule an inspection and fund our secure escrow account once they're ready to purchase.</p>
                        </div>
                         <!-- Step -->
                         <div class="text-center">
                            <div class="mb-4 inline-flex items-center justify-center w-16 h-16 rounded-full bg-white border-2 border-blue-500 text-blue-600 font-bold text-2xl shadow-md">3</div>
                            <h3 class="font-bold text-xl text-slate-900 mb-2">Sign & Exchange</h3>
                            <p class="text-slate-600">We handle all digital paperwork. Once complete, the buyer gets the car and we release funds to the seller.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-white py-12">
        <div class="container mx-auto px-6 text-center">
            <p class="text-slate-400 mb-4">Follow us for launch updates:</p>
            <div class="flex justify-center space-x-6 mb-8">
                <a href="#" class="text-slate-400 hover:text-white transition-transform hover:scale-110">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.71v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" /></svg>
                </a>
            </div>
            <p class="text-slate-500 text-sm">&copy; 2025 Autopeer. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        // --- Countdown Timer Logic ---
        const launchDate = new Date();
        launchDate.setDate(launchDate.getDate() + 45); // Set countdown for 45 days
        const launchTime = launchDate.getTime();
        const daysEl = document.getElementById('days'), hoursEl = document.getElementById('hours'), minutesEl = document.getElementById('minutes'), secondsEl = document.getElementById('seconds');
        const countdownInterval = setInterval(() => {
            const now = new Date().getTime();
            const distance = launchTime - now;
            if (distance < 0) {
                clearInterval(countdownInterval);
                document.getElementById('countdown').innerHTML = '<div class="col-span-4 text-xl font-bold text-green-400">We Have Launched!</div>';
                return;
            }
            daysEl.textContent = String(Math.floor(distance / (1000 * 60 * 60 * 24))).padStart(2, '0');
            hoursEl.textContent = String(Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))).padStart(2, '0');
            minutesEl.textContent = String(Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60))).padStart(2, '0');
            secondsEl.textContent = String(Math.floor((distance % (1000 * 60)) / 1000)).padStart(2, '0');
        }, 1000);

        // --- Form Submission Logic ---
        const waitlistForm = document.getElementById('waitlist-form');
        const emailInput = document.getElementById('email-input');
        const successMessage = document.getElementById('success-message');
        waitlistForm.addEventListener('submit', (e) => {
            e.preventDefault();
            console.log(`Email submitted: ${emailInput.value}`);
            waitlistForm.style.display = 'none';
            successMessage.style.display = 'block';
        });
    </script>
</body>
</html>
